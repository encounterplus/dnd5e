{
  "debug": false,
  "spacing": 8,
  "padding": [
    16
  ],
  "views": [
    {
      "type": "hStack",
      "spacing": 12,
      "alignment": "center",
      "views": [
        {
          "style": "title",
          "value": "{{name}}",
          "link": "https://www.google.com/search?tbm=isch&q=dnd+5e+{{name}}"
        },
        {
          "type": "image",
          "value": "{{token}}",
          "width": 30,
          "height": 30,
          "alignment": "top",
          "imageResizeMode": "aspectFill",
          "cornerRadius": 8,
          "link": "{{token}}"
        },
      ]
    },
    {
      "type": "text",
      "value": "{{descr}}"
    },
    {
      "type": "divider"
    },
    {
      "type": "text",
      "value": "{% include 'species-primary.md' %}"
    },
    {
      "type": "text",
      "title": "Common.Notes",
      "value": "{{notes}}",
    },
    {
      "type": "image",
      "value": "{{image}}",
      "link": "{{image}}"
    },
    {
      "type": "text",
      "value": "{{footer}}"
    },
    {
      "type": "tags",
      "attribute": "tags"
    }
  ]
}