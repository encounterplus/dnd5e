{
  "debug": false,
  "spacing": 8,
  "padding": [
    8
  ],
  "views": [
    {
      "type": "partial",
      "value": "monster-stats-new",
      "visibleIf": "attributes.ruleset == '5.5e'"
    },
    {
      "type": "partial",
      "value": "monster-stats",
      "visibleIf": "attributes.ruleset == '5e' or attributes.ruleset == null"
    },
    {
      "type": "vStack",
      "spacing": 8,
      "padding": [8],
      "views": [
        {
          "type": "text",
          "value": "{{descr}}",
        }, 
        {
          "type": "text",
          "title": "Common.Notes",
          "value": "{{notes}}",
        },
        {
          "type": "image",
          "value": "{{image}}",
          "link": "{{image}}",
          "custom": {
            "async": true
          }
        },
        {
          "type": "text",
          "value": "{{footer}}"
        }, 
        {
          "type": "tags",
          "attribute": "tags"
        }
      ]
    }
  ]
}