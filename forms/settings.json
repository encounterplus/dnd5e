{
  "title": "Settings",
  "sections": [
    {
      "type": "group",
      "title": "Common.General",
      "fields": [
        {
          "type": "picker",
          "title": "Settings.DefaultRuleset",
          "placeholder": "Ruleset.DnD5e",
          "attribute": "ruleset",
          "attributeType": "Ruleset"
        }
      ]
    },
    {
      "type": "group",
      "title": "Common.Locale",
      "fields": [
        {
          "type": "picker",
          "title": "Common.Language",
          "placeholder": "Common.Default",
          "attribute": "language",
          "attributeType": "SystemLanguage"
        },
        {
          "type": "picker",
          "title": "Common.Measurement",
          "placeholder": "Common.Default",
          "attribute": "measurement",
          "attributeType": "MeasurementSystem",
          "defaultValue": "imperial"
        },
      ]
    },
    {
      "type": "group",
      "title": "Settings.CombatTracker",
      "fields": [
        {
          "type": "picker",
          "title": "Settings.AutoRollInitiative",
          "placeholder": "Common.None",
          "defaultValue": "hostileAndNeutral",
          "attribute": "combat.initiative.autoRoll",
          "attributeType": "InitiativeRollType",
        },
        {
          "type": "picker",
          "title": "Settings.GroupInitiativeBy",
          "placeholder": "Common.None",
          "attribute": "combat.initiative.group",
          "attributeType": "InitiativeGroupType",
        },
        {
          "type": "toggle",
          "title": "Settings.ReRollInitiativeEveryRound",
          "attribute": "combat.initiative.everyRound",
        },
        {
          "type": "picker",
          "title": "Settings.CombatantImageType",
          "placeholder": "Common.Default",
          "attribute": "entities.Default.combatant.image",
          "attributeType": "CombatImageDisplayType",
        },
      ]
    },
    {
      "type": "group",
      "title": "Settings.UI",
      "fields": [
        {
          "type": "picker",
          "title": "Settings.CollectionImageType",
          "placeholder": "Common.Default",
          "attribute": "entities.Default.collection.image",
          "attributeType": "ListImageDisplayType",
        },
        {
          "type": "picker",
          "title": "Settings.MonsterCollectionImageType",
          "placeholder": "Common.Default",
          "attribute": "entities.Monster.collection.image",
          "attributeType": "ListImageDisplayType",
        },
         {
          "type": "picker",
          "title": "Settings.CharacterCollectionImageType",
          "placeholder": "Common.Default",
          "attribute": "entities.Character.collection.image",
          "attributeType": "ListImageDisplayType",
        },
      ]
    },
  ]
}
