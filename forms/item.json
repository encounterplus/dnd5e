{
  "title": "Item",
  "sections": [
    {
      "type": "group",
      "fields": [
        {
          "title": "Common.Type",
          "type": "picker",
          "attribute": "data.type",
          "attributeType": "ItemType"
        },
        {
          "title": "Common.TypeDetail",
          "type": "text",
          "attribute": "data.typeDetail",
          "visibleIf": "data.type == 'armor' or data.type == 'lightArmor' or data.type == 'mediumArmor' or data.type == 'heavyArmor' or data.type == 'weapon' or data.type == 'meleeWeapon' or data.type == 'rangedWeapon'",
        },
        {
          "title": "Item.Rarity",
          "type": "picker",
          "attribute": "data.rarity",
          "attributeType": "ItemRarity"
        },
        {
          "title": "Item.Attunement",
          "type": "toggle",
          "attribute": "data.attunement",
        },
        {
          "title": "Item.AttunementDetail",
          "type": "text",
          "attribute": "data.attunementDetail",
          "visibleIf": "{{data.attunement}}",
        },
        {
          "title": "Item.Value",
          "units": "gp",
          "type": "decimal",
          "attribute": "data.value"
        },
        {
          "title": "Item.Weight",
          "units": "lb",
          "type": "decimal",
          "attribute": "data.weight"
        }
      ]
    },
    {
      "title": "Item.ArmorProperties",
      "type": "group",
      "visibleIf": "data.type == 'armor' or data.type == 'lightArmor' or data.type == 'mediumArmor' or data.type == 'heavyArmor' or data.type == 'shield'",
      "fields": [
        {
          "title": "Common.ArmorClass",
          "type": "number",
          "attribute": "data.ac"
        },
        {
          "title": "Item.StealthCheckDisadvantage",
          "type": "toggle",
          "attribute": "data.stealth"
        },
        {
          "title": "Item.STRRequirement",
          "type": "number",
          "attribute": "data.str"
        },
      ]
    },
    {
      "title": "Item.WeaponProperties",
      "visibleIf": "data.type == 'weapon' or data.type == 'meleeWeapon' or data.type == 'rangedWeapon' or data.type == 'ammunition'",
      "type": "group",
      "fields": [
        {
          "title": "Item.Properties",
          "type": "multiPicker",
          "attribute": "data.properties",
          "attributeType": "ItemProperty"
        },
        {
          "title": "Item.Mastery",
          "type": "picker",
          "attribute": "data.mastery",
          "attributeType": "ItemMastery"
        },
        {
          "title": "Common.Damage",
          "type": "text",
          "attribute": "data.dmg1"
        },
        {
          "title": "Item.DamageVersatile",
          "type": "text",
          "attribute": "data.dmg2",
          "visibleIf": "'versatile' in data.properties",
        },
        {
          "title": "Item.DamageType",
          "type": "picker",
          "attribute": "data.dmgType",
          "attributeType": "Damage"
        },
        {
          "title": "Item.Range",
          "units": "ft",
          "type": "text",
          "attribute": "data.range"
        },
      ]
    },
    {
      "title": "Item.OtherProperties",
      "type": "group",
      "visibleIf": "data.type == 'adventuringGear' or data.type == 'wondrousItem' or data.type == 'equipmentPack'",
      "fields": [
        {
          "title": "Item.Container",
          "type": "toggle",
          "attribute": "data.container",
        },
        {
          "title": "Item.ContainerCapacity",
          "units": "lb",
          "placeholder": "Common.Unlimited",
          "type": "number",
          "attribute": "data.capacity",
          "visibleIf": "{{data.container}}",
        },
      ]
    },
  ]
}